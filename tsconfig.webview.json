{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020", "DOM"],
    "jsx":              "react",
    "module":           "ES2020",
    "moduleResolution": "node",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "resolveJsonModule": true,
    "noEmit":           true
  },
  "include": ["src/webview/**/*", "src/data/types.ts", "src/lib/format.ts"],
  "exclude": ["node_modules"]
}
